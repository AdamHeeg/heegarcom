@rendermode InteractiveWebAssembly

<div class="mx-auto max-w-4xl px-6 pb-24">
    <div class="flex flex-wrap gap-2">
        <button @onclick="@(() => Select(null))" class="@TagClass(null)">All</button>
        @foreach (var tag in AllTags)
        {
            <button @onclick="@(() => Select(tag))" class="@TagClass(tag)">@tag</button>
        }
    </div>

    <div class="mt-10 space-y-6">
        @foreach (var p in Filtered)
        {
            <ProjectCard Item="p" />
        }
    </div>
</div>

@code {
    private string? selectedTag;

    private void Select(string? tag) => selectedTag = tag;

    private IReadOnlyList<ProjectItem> Items => ProjectCatalog.All;

    private IEnumerable<ProjectItem> Filtered =>
        selectedTag is null ? Items : Items.Where(p => p.Tags.Contains(selectedTag));

    private IEnumerable<string> AllTags =>
        Items.SelectMany(p => p.Tags).Distinct().OrderBy(t => t);

    private string TagClass(string? tag) =>
        (selectedTag == tag
            ? "bg-orange text-white "
            : "border border-line text-ink hover:border-orange hover:text-orange ")
        + "rounded-full px-3.5 py-1.5 text-sm font-medium transition-colors";
}
