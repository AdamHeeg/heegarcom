@using System.Net.Http.Json
@inject HttpClient Http

<div class="mx-auto max-w-3xl px-6 pb-24">
    <div class="grid gap-3 sm:grid-cols-2">
        <div>
            <label class="mb-1 block text-xs font-semibold uppercase tracking-widest text-muted">ICD-10</label>
            <input value="@icdText" @oninput="OnIcd" type="search" autocomplete="off"
                   placeholder="e.g. glaucoma, cataract, H40"
                   class="w-full rounded-md border border-line bg-white px-4 py-3 text-ink shadow-sm outline-none transition-colors focus:border-orange" />
        </div>
        <div>
            <label class="mb-1 block text-xs font-semibold uppercase tracking-widest text-muted">SNOMED CT</label>
            <input value="@snomedText" @oninput="OnSnomed" type="search" autocomplete="off"
                   placeholder="e.g. glaucoma, 23986001"
                   class="w-full rounded-md border border-line bg-white px-4 py-3 text-ink shadow-sm outline-none transition-colors focus:border-orange" />
        </div>
    </div>

    @if (loading)
    {
        <p class="mt-4 text-sm text-muted">Searching…</p>
    }
    else if (searched && rows.Count == 0)
    {
        <p class="mt-4 text-sm text-muted">No matches.</p>
    }
    else if (rows.Count > 0)
    {
        <p class="mt-4 text-sm text-muted">@rows.Count result@(rows.Count == 1 ? "" : "s")@(rows.Count == 100 ? " (showing first 100)" : "")</p>
        <div class="mt-3 overflow-x-auto">
            <table class="w-full border-collapse text-left text-sm">
                <thead>
                    <tr class="border-b border-line text-xs uppercase tracking-widest text-muted">
                        <th class="py-2 pr-4">ICD-10</th>
                        <th class="py-2 pr-4">Description</th>
                        <th class="py-2 pr-4">SNOMED CT</th>
                        <th class="py-2">SNOMED term</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in rows)
                    {
                        <tr class="border-b border-line align-top">
                            <td class="whitespace-nowrap py-2 pr-4 font-mono font-medium text-navy">@r.IcdCode</td>
                            <td class="py-2 pr-4 text-ink">@r.IcdDescription</td>
                            <td class="whitespace-nowrap py-2 pr-4 font-mono text-muted">@r.SnomedId</td>
                            <td class="py-2 text-ink">@r.SnomedTerm</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private string icdText = "";
    private string snomedText = "";
    private List<MapRow> rows = new();
    private bool loading;
    private bool searched;
    private CancellationTokenSource? cts;

    private Task OnIcd(ChangeEventArgs e)
    {
        icdText = e.Value?.ToString() ?? "";
        snomedText = "";
        return Search("icd", icdText);
    }

    private Task OnSnomed(ChangeEventArgs e)
    {
        snomedText = e.Value?.ToString() ?? "";
        icdText = "";
        return Search("snomed", snomedText);
    }

    private async Task Search(string field, string value)
    {
        cts?.Cancel();
        cts = new CancellationTokenSource();
        var token = cts.Token;

        if (value.Trim().Length < 2)
        {
            rows = new();
            searched = false;
            loading = false;
            StateHasChanged();
            return;
        }

        try
        {
            await Task.Delay(250, token); // debounce
            loading = true;
            StateHasChanged();

            var url = $"api/terminology/search?{field}={Uri.EscapeDataString(value)}";
            var found = await Http.GetFromJsonAsync<List<MapRow>>(url, token);

            rows = found ?? new();
            searched = true;
        }
        catch (TaskCanceledException)
        {
            // superseded by a newer keystroke — ignore
        }
        catch
        {
            rows = new();
            searched = true;
        }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                loading = false;
                StateHasChanged();
            }
        }
    }

    private record MapRow(string IcdCode, string IcdDescription, string SnomedId, string SnomedTerm);
}
