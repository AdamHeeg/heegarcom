@using System.Net.Http.Json
@inject HttpClient Http

<div class="mx-auto max-w-3xl px-6 pb-24">
    <input @oninput="OnInput" type="search" autocomplete="off"
           placeholder="Search an eye diagnosis or ICD-10 code — e.g. glaucoma, cataract, H40"
           class="w-full rounded-md border border-line bg-white px-4 py-3 text-ink shadow-sm outline-none transition-colors focus:border-orange" />

    @if (loading)
    {
        <p class="mt-4 text-sm text-muted">Searching…</p>
    }
    else if (searched && results.Count == 0)
    {
        <p class="mt-4 text-sm text-muted">No matches for &ldquo;@query&rdquo;.</p>
    }
    else if (results.Count > 0)
    {
        <p class="mt-4 text-sm text-muted">@results.Count result@(results.Count == 1 ? "" : "s")</p>
        <div class="mt-3 overflow-x-auto">
            <table class="w-full border-collapse text-left text-sm">
                <thead>
                    <tr class="border-b border-line text-xs uppercase tracking-widest text-muted">
                        <th class="py-2 pr-4">ICD-10</th>
                        <th class="py-2 pr-4">Description</th>
                        <th class="py-2">SNOMED CT</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in results)
                    {
                        <tr class="border-b border-line align-top">
                            <td class="whitespace-nowrap py-2 pr-4 font-mono font-medium text-navy">@r.Code</td>
                            <td class="py-2 pr-4 text-ink">@r.Description</td>
                            <td class="py-2 text-muted">
                                @if (r.Snomed.Count == 0)
                                {
                                    <span>&mdash;</span>
                                }
                                else
                                {
                                    @foreach (var s in r.Snomed)
                                    {
                                        <div>@s.Term <span class="text-xs">(@s.Id)</span></div>
                                    }
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private string query = "";
    private List<Result> results = new();
    private bool loading;
    private bool searched;
    private CancellationTokenSource? cts;

    private async Task OnInput(ChangeEventArgs e)
    {
        query = e.Value?.ToString() ?? "";

        cts?.Cancel();
        cts = new CancellationTokenSource();
        var token = cts.Token;

        if (query.Trim().Length < 2)
        {
            results = new();
            searched = false;
            loading = false;
            StateHasChanged();
            return;
        }

        try
        {
            await Task.Delay(250, token); // debounce
            loading = true;
            StateHasChanged();

            var found = await Http.GetFromJsonAsync<List<Result>>(
                $"api/icd/search?q={Uri.EscapeDataString(query)}", token);

            results = found ?? new();
            searched = true;
        }
        catch (TaskCanceledException)
        {
            // superseded by a newer keystroke — ignore
        }
        catch
        {
            results = new();
            searched = true;
        }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                loading = false;
                StateHasChanged();
            }
        }
    }

    private record Result(string Code, string Description, List<Snomed> Snomed);
    private record Snomed(string Id, string Term);
}
