@implements IDisposable

<div class="mx-auto max-w-3xl px-6 pb-24">
    <div class="flex justify-center">
        <div class="relative">
            <img src="img/tribetime/@Current.File" alt="@Current.Caption"
                 class="h-[540px] w-auto rounded-2xl border border-line shadow-sm" />

            <button @onclick="Prev" aria-label="Previous screenshot"
                    class="absolute left-2 top-1/2 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-navy/70 text-white transition hover:bg-navy">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 18l-6-6 6-6" />
                </svg>
            </button>
            <button @onclick="Next" aria-label="Next screenshot"
                    class="absolute right-2 top-1/2 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-navy/70 text-white transition hover:bg-navy">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 6l6 6-6 6" />
                </svg>
            </button>
        </div>
    </div>

    <p class="mt-3 text-center text-sm text-muted">@Current.Caption</p>

    <div class="mt-3 flex justify-center gap-2">
        @for (var i = 0; i < Shots.Length; i++)
        {
            var idx = i;
            <button @onclick="() => Go(idx)" aria-label="@($"Go to screenshot {idx + 1}")"
                    class="h-2 w-2 rounded-full transition-colors @(i == index ? "bg-orange" : "bg-line")"></button>
        }
    </div>
</div>

@code {
    private record Shot(string File, string Caption);

    private static readonly Shot[] Shots =
    {
        new("calendar.jpg", "Shared calendar"),
        new("tribes.jpg", "My Tribes"),
        new("notifications.jpg", "Notifications"),
        new("create-notification.jpg", "Create a notification"),
        new("profile.jpg", "Profile & themes"),
    };

    private int index;
    private CancellationTokenSource? cts;

    private Shot Current => Shots[index];

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender) Restart();
    }

    // Restart the 5-second auto-advance countdown (also called after manual navigation).
    private void Restart()
    {
        cts?.Cancel();
        cts = new CancellationTokenSource();
        _ = AutoAdvance(cts.Token);
    }

    private async Task AutoAdvance(CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested)
            {
                await Task.Delay(5000, token);
                index = (index + 1) % Shots.Length;
                StateHasChanged();
            }
        }
        catch (TaskCanceledException)
        {
            // superseded by manual navigation or disposed
        }
    }

    private void Next() { index = (index + 1) % Shots.Length; Restart(); }
    private void Prev() { index = (index - 1 + Shots.Length) % Shots.Length; Restart(); }
    private void Go(int i) { index = i; Restart(); }

    public void Dispose() => cts?.Cancel();
}
